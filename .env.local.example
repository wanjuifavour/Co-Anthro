# Xata Database
# Get these from your Xata workspace dashboard
XATA_API_KEY=xau_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
XATA_DB_URL=https://your-workspace-abc123.eu-west-1.xata.sh/db/hackathon-hub:main

# Auth — pick any strong password for your team
TEAM_PASSWORD=your-team-password-here

# Used for signing the auth cookie (generate a random 32+ char string)
AUTH_SECRET=replace-with-a-long-random-secret-string
